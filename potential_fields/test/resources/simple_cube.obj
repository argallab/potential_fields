# Simple unit cube centered at origin spanning [-0.5, 0.5] on each axis

v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

# Triangles (two per face), counter-clockwise winding when looking from outside
# Bottom (z = -0.5)
f 1 2 3
f 1 3 4
# Top (z = +0.5)
f 5 7 6
f 5 8 7
# -Y side (y = -0.5)
f 1 5 6
f 1 6 2
# +X side (x = +0.5)
f 2 6 7
f 2 7 3
# +Y side (y = +0.5)
f 3 7 8
f 3 8 4
# -X side (x = -0.5)
f 4 8 5
f 4 5 1
