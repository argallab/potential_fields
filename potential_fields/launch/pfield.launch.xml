<launch>
<arg name="use_rviz" default="true" description="Whether to launch RViz or not."/>
<arg name="rviz_config" default="$(find-pkg-share potential_fields)/config/view_pfield.rviz" description="The RVIZ config file (.rviz)"/>
<arg name="rviz_fixed_frame" default="world" description="The fixed frame for RVIZ"/>
<arg name="use_xacro" default="true" description="Whether to use xacro to process the URDF file."/>
<arg name="robot_urdf_xacro" description="The XACRO URDF file for the robot"/>
<arg name="robot_urdf" description="The URDF file for the robot"/>

  <!-- RViz -->
  <node pkg="rviz2" exec="rviz2" args="-d $(var rviz_config) --fixed-frame $(var rviz_fixed_frame)" if="$(var use_rviz)" output="screen">
    <param name="use_sim_time" value="true"/>
  </node>

  <!-- Potential Field Manager -->
  <node pkg="potential_fields" exec="pfield_manager" name="pfield_manager" output="screen">
    <param from="$(find-pkg-share potential_fields)/config/pfield_config.yaml"/>
    <param name="fixed_frame" value="$(var rviz_fixed_frame)"/>
  </node>

  <!-- Robot Parser -->
  <node pkg="potential_fields" exec="robot_parser" name="robot_parser" output="screen" if="$(eval \'$(var use_xacro)\'==\'false\')">
    <param from="$(find-pkg-share potential_fields)/config/pfield_config.yaml"/>
    <param name="fixed_frame" value="$(var rviz_fixed_frame)"/>
    <param name="robot_description" value="$(var robot_urdf)"/>
  </node>
  <node pkg="potential_fields" exec="robot_parser" name="robot_parser" output="screen" if="$(var use_xacro)">
    <param from="$(find-pkg-share potential_fields)/config/pfield_config.yaml"/>
    <param name="fixed_frame" value="$(var rviz_fixed_frame)"/>
    <param name="robot_description" value="$(command 'xacro $(var robot_urdf_xacro)')"/>
  </node>
</launch>
