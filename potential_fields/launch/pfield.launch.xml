<launch>
<arg name="use_jsp" default="gui" description="The JointState Publisher to launch. ['gui', 'jsp', 'none']"/>
<arg name="use_rviz" default="true" description="Whether to launch RViz or not."/>
<arg name="rviz_config" default="$(find-pkg-share potential_fields)/config/view_pfield.rviz" description="The RVIZ config file (.rviz)"/>
<arg name="rviz_fixed_frame" default="world" description="The fixed frame for RVIZ"/>
<arg name="use_xacro" default="true" description="Whether to use xacro to process the URDF file."/>
<arg name="robot_urdf_xacro" default="" description="The XACRO URDF file for the robot"/>
<arg name="robot_urdf" default="" description="The URDF file for the robot"/>
<arg name="robot_state_publisher_frequency" default="50.0" description="The frequency (in Hz) for the robot_state_publisher to publish transforms."/>
<arg name="joint_state_publisher_frequency" default="50.0" description="The frequency (in Hz) for the joint_state_publisher to publish joint states."/>
<arg name="planning_tf_prefix" default="planning_" description="Prefix for planning robot's TF frames"/>


  <!-- RViz -->
  <node pkg="rviz2" exec="rviz2" args="-d $(var rviz_config) --fixed-frame $(var rviz_fixed_frame)" if="$(var use_rviz)" output="screen">
    <param name="use_sim_time" value="true"/>
  </node>

  <!-- Potential Field Manager -->
  <node pkg="potential_fields" exec="pfield_manager" name="pfield_manager" output="screen">
    <param from="$(find-pkg-share potential_fields)/config/pfield_config.yaml"/>
    <param name="fixed_frame" value="$(var rviz_fixed_frame)"/>
  </node>

  <!-- Robot Parser -->
  <node pkg="potential_fields" exec="robot_parser" name="robot_parser" output="screen" if="$(eval \'$(var use_xacro)\'==\'false\')">
    <param from="$(find-pkg-share potential_fields)/config/pfield_config.yaml"/>
    <param name="fixed_frame" value="$(var rviz_fixed_frame)"/>
    <param name="robot_description" value="$(command 'cat $(var robot_urdf)')" type="str"/>
  </node>
  <node pkg="potential_fields" exec="robot_parser" name="robot_parser" output="screen" if="$(var use_xacro)">
    <param from="$(find-pkg-share potential_fields)/config/pfield_config.yaml"/>
    <param name="fixed_frame" value="$(var rviz_fixed_frame)"/>
    <param name="robot_description" value="$(command 'xacro $(var robot_urdf_xacro)')" type="str"/>
    <param name="use_jsp" value="$(var use_jsp)"/>
  </node>

  <!-- Planning Robot State Publisher -->
  <node pkg="robot_state_publisher" exec="robot_state_publisher" name="planning_robot_state_publisher" output="screen" if="$(var use_xacro)" >
    <param name="publish_frequency" value="$(var robot_state_publisher_frequency)"/>
    <param name="robot_description" value="$(command 'xacro $(var robot_urdf_xacro)')" type="str"/>
    <!-- ROS 2 uses 'frame_prefix' to namespace all published TF frames -->
    <param name="frame_prefix" value="$(var planning_tf_prefix)"/>
    <remap from="joint_states" to="planning_joint_states"/>
  </node>
  <node pkg="robot_state_publisher" exec="robot_state_publisher" name="planning_robot_state_publisher" output="screen" if="$(eval \'$(var use_xacro)\'==\'false\')" >
    <param name="publish_frequency" value="$(var robot_state_publisher_frequency)"/>
    <param name="robot_description" value="$(command 'cat $(var robot_urdf)')" type="str"/>
    <!-- ROS 2 uses 'frame_prefix' to namespace all published TF frames -->
    <param name="frame_prefix" value="$(var planning_tf_prefix)"/>
    <remap from="joint_states" to="planning_joint_states"/>
  </node>

  <!-- Planning Joint State Publisher -->
  <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui" name="planning_joint_state_publisher_gui" if="$(eval \'$(var use_jsp)\'==\'gui\')">
    <param name="rate" value="$(var joint_state_publisher_frequency)"/>
    <param name="robot_description" value="" type="str"/>
    <remap from="joint_states" to="planning_joint_states"/>
  </node>
  <node pkg="joint_state_publisher" exec="joint_state_publisher" name="planning_joint_state_publisher" if="$(eval \'$(var use_jsp)\'==\'jsp\')">
    <param name="rate" value="$(var joint_state_publisher_frequency)"/>
    <param name="robot_description" value="" type="str"/>
    <remap from="joint_states" to="planning_joint_states"/>
  </node>
</launch>
