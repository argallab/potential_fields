<?xml version="1.0"?>
<robot name="turtlebot" xmlns:xacro="http://wiki.ros.org/wiki/xacro">
  <!-- Configurable Properties -->
  <xacro:property name="platform_height" value="2.0"/>
  <xacro:property name="wheel_radius" value="0.15"/>
  <xacro:property name="max_velocity" value="2.0"/>
  <xacro:property name="gravity_accel" value="9.81"/>
  <!-- Other Properties -->
  <xacro:property name="remaining_length" value="${platform_height - wheel_radius}"/>
  <xacro:property name="cube_length" value="${wheel_radius}"/>
  <xacro:property name="stem_length" value="${0.85 * remaining_length}"/>
  <xacro:property name="wheel_stem_length" value="${0.15 * remaining_length}"/>

  <!-- Turtle Links -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${cube_length} ${cube_length} ${cube_length}"/>
      </geometry>
      <material name="transparent_mat">
        <color rgba="0.8 0.8 0.8 0.5"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${cube_length} ${cube_length} ${cube_length}"/>
      </geometry>
      <!-- defaults to origin (0 0 0) relative to link frame -->
    </collision>
  </link>

  <link name="stem">
    <visual>
      <geometry>
        <cylinder radius="${0.03 * stem_length}" length="${stem_length}"/>
      </geometry>
      <material name="grey_mat">
        <color rgba="0.128 0.128 0.128 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${0.03 * stem_length}" length="${stem_length}"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_stem">
    <visual>
      <geometry>
        <cylinder radius="${0.15 * wheel_radius}" length="${wheel_stem_length}"/>
      </geometry>
      <material name="grey_mat">
        <color rgba="0.128 0.128 0.128 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${0.15 * wheel_radius}" length="${wheel_stem_length}"/>
      </geometry>
    </collision>
  </link>

  <link name="platform">
    <visual>
      <geometry>
        <cylinder radius="${(0.49*stem_length)}" length="${0.05*stem_length}"/>
      </geometry>
      <material name="green_mat">
        <color rgba="0 1 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${(0.49*stem_length)}" length="${0.05*stem_length}"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${0.3*wheel_radius}"/>
      </geometry>
      <material name="black_mat">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${0.3*wheel_radius}"/>
      </geometry>
    </collision>
  </link>

  <!-- Joints -->
  <joint name="base_to_stem" type="fixed">
    <parent link="base_link"/>
    <child link="stem"/>
    <origin xyz="0.0 0.0 ${0.5*cube_length + 0.5*stem_length}"/>
  </joint>

  <joint name="stem_to_platform" type="continuous">
    <parent link="stem"/>
    <child link="platform"/>
    <axis xyz="0.0 1.0 0.0"/>
    <origin xyz="0.0 0.0 ${0.5*stem_length}"/>
  </joint>

  <joint name="base_to_wheel_stem" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_stem"/>
    <axis xyz="0.0 0.0 1.0"/>
    <origin xyz="0.0 0.0 ${-1*(0.5*cube_length + 0.5*wheel_stem_length)}"/>
  </joint>

  <joint name="wheel_stem_to_wheel" type="continuous">
    <parent link="wheel_stem"/>
    <child link="wheel"/>
    <origin xyz="0.0 0.0 ${-0.5*wheel_stem_length-wheel_radius}" rpy="${pi/2} 0.0 0.0"/>
    <axis xyz="0.0 0.0 1.0"/>
  </joint>
</robot>
